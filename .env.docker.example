# 复制为 .env 后由 docker compose 读取（与 docker-compose.yml 同目录）
# cp .env.docker.example .env

MYSQL_DATABASE=auto_amazon
MYSQL_USER=auto_amazon
# 数据库密码只能使用 ASCII。若宿主机 shell 曾 export MYSQL_PASSWORD=中文，会覆盖 compose 里对 ${MYSQL_PASSWORD} 的替换并导致 PyMySQL 报错；当前 compose 已改为只读 .env 注入。
MYSQL_PASSWORD=ChangeMe_AppUser_9xK2
MYSQL_ROOT_PASSWORD=ChangeMe_Root_7mQ4

# 宿主机访问 Nginx 的端口
HTTP_PORT=8080

# Django CSRF 受信任来源（逗号分隔，需带 http/https 协议）
CSRF_TRUSTED_ORIGINS=http://192.168.11.143:8080
